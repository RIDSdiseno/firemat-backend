generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  productos Producto[]
}

model Producto {
  id                       Int                        @id @default(autoincrement())
  nombre                   String
  descripcion              String?
  stock                    Int
  ubicacion                String?
  createdAt                DateTime                   @default(now())
  precio                   Float
  minStock                 Int                        @default(0)
  activo                   Boolean                    @default(true)
  criticidad               String                     @default("Media")
  imagen                   String?
  categoriaId              Int
  stockReservado           Int                        @default(0)
  CotizacionFirematDetalle CotizacionFirematDetalle[]
  movimientos              Movimiento[]
  oportunidades            Oportunidad[]
  categoria                Categoria                  @relation(fields: [categoriaId], references: [id])
  ventas                   Venta[]
  VentaDetalle             VentaDetalle[]
}

model Movimiento {
  id            Int      @id @default(autoincrement())
  tipo          String
  cantidad      Int
  stockAnterior Int
  stockNuevo    Int
  motivo        String?
  documento     String?
  createdAt     DateTime @default(now())
  productoId    Int
  userId        Int?
  producto      Producto @relation(fields: [productoId], references: [id])
}

model user {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Venta {
  id                 Int            @id @default(autoincrement())
  productoId         Int
  cliente            String
  contacto           String?
  cantidad           Int
  precio             Float
  total              Float
  estado             String         @default("PROSPECTO")
  responsable        String?
  fechaCierre        DateTime?
  createdAt          DateTime       @default(now())
  fechaProximaAccion DateTime?
  origen             String?
  probabilidad       Float?
  proximaAccion      String?
  producto           Producto       @relation(fields: [productoId], references: [id])
  detalles           VentaDetalle[]
}

model VentaDetalle {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precio     Float
  subtotal   Float
  producto   Producto @relation(fields: [productoId], references: [id])
  venta      Venta    @relation(fields: [ventaId], references: [id])
}

model Cliente {
  id            Int           @id @default(autoincrement())
  nombre        String
  rut           String?       @unique
  email         String?
  telefono      String?
  direccion     String?
  createdAt     DateTime      @default(now())
  oportunidades Oportunidad[]
}

model Oportunidad {
  id                 Int       @id @default(autoincrement())
  clienteId          Int
  titulo             String
  descripcion        String?
  unidadNegocio      String
  estado             String    @default("PROSPECTO")
  etapa              String    @default("PROSPECTO")
  montoEstimado      Float?
  proximaAccion      String?
  fechaProximaAccion DateTime?
  probabilidad       Int?
  createdAt          DateTime  @default(now())
  productoId         Int?
  cliente            Cliente   @relation(fields: [clienteId], references: [id])
  producto           Producto? @relation(fields: [productoId], references: [id])
}

model CotizacionFiremat {
  id                       Int                        @id @default(autoincrement())
  numero                   String                     @unique
  cliente                  String
  contacto                 String?
  tipoCliente              String?
  responsable              String?
  estado                   String                     @default("BORRADOR")
  subtotal                 Float                      @default(0)
  descuento                Float                      @default(0)
  impuesto                 Float                      @default(0)
  total                    Float                      @default(0)
  fechaCotizacion          DateTime                   @default(now())
  fechaVencimiento         DateTime?
  fechaEnvio               DateTime?
  fechaSeguimiento         DateTime?
  fechaCierre              DateTime?
  probabilidadCierre       Int?
  comentariosCliente       String?
  objeciones               String?
  observaciones            String?
  motivoPerdida            String?
  motivoPostergacion       String?
  fechaReactivacion        DateTime?
  version                  Int                        @default(1)
  esActual                 Boolean                    @default(true)
  cotizacionBaseId         Int?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  CotizacionFirematDetalle CotizacionFirematDetalle[]
}

model CotizacionFirematDetalle {
  id                Int               @id @default(autoincrement())
  cotizacionId      Int
  productoId        Int
  cantidad          Int
  precioUnitario    Float
  descuentoPct      Float             @default(0)
  subtotal          Float
  stockDisponible   Int?
  observacion       String?
  CotizacionFiremat CotizacionFiremat @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  Producto          Producto          @relation(fields: [productoId], references: [id])
}
